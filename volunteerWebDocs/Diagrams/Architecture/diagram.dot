digraph Architecture_Volunteer_Web_App {
    graph [
        rankdir=LR,
        splines=ortho,
        bgcolor="white",
        pad=0.25,
        nodesep=0.9,
        ranksep=1.0,
        fontname="Segoe UI",
        fontsize=12
    ];

    node [
        fontname="Segoe UI",
        fontsize=10,
        style="rounded,filled",
        color="#6B7A90"
    ];

    edge [
        fontname="Segoe UI",
        fontsize=9
    ];

    subgraph cluster_client {
        label="Клиентский слой";
        style="rounded";
        color="#AAB7C4";

        browser [label="Пользователь\n(веб-браузер)", shape=box, fillcolor="#F7F9FC"];
        spa [label="Клиентское приложение\nReact SPA", shape=box, fillcolor="#EAF3FF"];
    }

    subgraph cluster_backend {
        label="Серверный слой (Node.js / Express)";
        style="rounded";
        color="#AAB7C4";

        api [label="Сервер приложений\nExpress API", shape=box, fillcolor="#EAF3FF"];

        auth [label="Модуль аутентификации\nи авторизации (JWT)", shape=component, fillcolor="#FFF4CC"];
        profiles [label="Модуль пользователей\nи профилей", shape=component, fillcolor="#FFF4CC"];
        events [label="Модуль мероприятий", shape=component, fillcolor="#FFF4CC"];
        applications [label="Модуль заявок\nна участие", shape=component, fillcolor="#FFF4CC"];
    }

    subgraph cluster_data {
        label="Слой хранения данных";
        style="rounded";
        color="#AAB7C4";

        db [label="PostgreSQL", shape=cylinder, fillcolor="#EAF3FF"];
    }

    browser -> spa [label="Взаимодействие\nчерез UI"];
    spa -> api [label="HTTP / JSON"];
    api -> auth [label="Проверка доступа"];
    api -> profiles [label="Работа с профилем"];
    api -> events [label="Чтение / изменение\nмероприятий"];
    api -> applications [label="Подача / отмена заявки,\nполучение списка заявок"];

    auth -> db [label="Пользователи,\nJWT-логика"];
    profiles -> db [label="Пользователи,\nпрофили"];
    events -> db [label="Мероприятия,\nкатегории"];
    applications -> db [label="Заявки,\nобновление мест"];
}