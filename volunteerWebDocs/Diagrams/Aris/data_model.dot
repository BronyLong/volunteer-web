digraph ARIS_Data_Model {
    graph [
        rankdir=LR,
        splines=ortho,
        bgcolor="white",
        pad=0.2,
        nodesep=0.9,
        ranksep=1.0,
        fontname="Segoe UI",
        fontsize=12
    ];

    node [
        shape=record,
        style="rounded,filled",
        fillcolor="#F7F9FC",
        color="#6B7A90",
        fontname="Segoe UI",
        fontsize=10
    ];

    edge [
        fontname="Segoe UI",
        fontsize=9
    ];

    User [label="{User|
id: UUID\l
email: string\l
password: string\l
role: UserRole\l
is_active: boolean\l
created_at: datetime\l
}"];

    Profile [label="{Profile|
user_id: UUID\l
first_name: string\l
last_name: string\l
phone: string\l
city: string\l
avatar_url: text\l
bio: text\l
vk_url: text\l
ok_url: text\l
max_url: text\l
}"];

    Category [label="{Category|
id: int\l
name: string\l
}"];

    Event [label="{Event|
id: UUID\l
title: string\l
description: text\l
start_at: datetime\l
location: string\l
participant_limit: int\l
available_slots: int\l
category_id: int\l
created_by: UUID\l
created_at: datetime\l
updated_at: datetime\l
}"];

    Application [label="{Application|
id: int\l
user_id: UUID\l
event_id: UUID\l
created_at: datetime\l
}"];

    User -> Profile [label="1 : 1", dir=both];
    User -> Event [label="1 : N\n(координатор создаёт)", dir=both];
    Category -> Event [label="1 : N", dir=both];
    User -> Application [label="1 : N", dir=both];
    Event -> Application [label="1 : N", dir=both];
}