digraph UML_UserSubsystem {
    graph [
        rankdir=TB,
        splines=ortho,
        nodesep=0.6,
        ranksep=0.9,
        bgcolor="white"
    ];

    node [shape=record, fontname="Segoe UI", fontsize=10, margin="0.15,0.08"];
    edge [fontname="Segoe UI", fontsize=9, arrowsize=0.8];

    User [label="{User|+ id: UUID\l+ email: string\l+ passwordHash: string\l+ role: UserRole\l+ isActive: boolean\l+ lastLogin: datetime\l|+ register()\l+ login()\l+ logout()\l+ changePassword()\l}"];

    Profile [label="{Profile <<abstract>>|+ userId: UUID\l+ firstName: string\l+ lastName: string\l+ middleName: string\l+ phone: string\l+ avatarUrl: text\l+ bio: text\l|+ updateProfile()\l}"];

    VolunteerProfile [label="{VolunteerProfile|+ city: string\l+ dateOfBirth: date\l|+ viewParticipationHistory()\l+ viewHoursStatistics()\l}"];

    CoordinatorProfile [label="{CoordinatorProfile|+ position: string\l+ department: string\l|+ createEvent()\l+ reviewApplications()\l+ confirmHours()\l}"];

    AdminProfile [label="{AdminProfile| |+ changeUserRole()\l+ blockUser()\l+ unblockUser()\l+ manageCategories()\l}"];

    RoleService [label="{RoleService| |+ authorize()\l+ checkPermission()\l+ assignRole()\l}"];
    AuthService [label="{AuthService| |+ issueJwt()\l+ verifyJwt()\l+ hashPassword()\l+ validateCredentials()\l}"];

    Profile -> VolunteerProfile [arrowhead="empty"];
    Profile -> CoordinatorProfile [arrowhead="empty"];
    Profile -> AdminProfile [arrowhead="empty"];

    User -> Profile [label="1 to 1", arrowhead="none"];
    User -> AuthService [label="uses", style="dashed", arrowhead="vee"];
    User -> RoleService [label="uses", style="dashed", arrowhead="vee"];
    AdminProfile -> RoleService [label="uses", style="dashed", arrowhead="vee"];
}
