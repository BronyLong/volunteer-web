digraph UseCase_Coordinator {
    rankdir=LR;
    graph [fontname="Segoe UI", fontsize=11];
    node [fontname="Segoe UI", fontsize=10];
    edge [fontname="Segoe UI", fontsize=9];

    coordinator [label="Координатор", shape=actor];

    subgraph cluster_system {
        label="Веб-приложение";
        style="rounded";

        uc_home     [label="Просмотр главной страницы", shape=ellipse];
        uc_events   [label="Просмотр списка\nмероприятий", shape=ellipse];
        uc_event    [label="Просмотр страницы\nмероприятия", shape=ellipse];
        uc_filter   [label="Фильтрация мероприятий", shape=ellipse];

        uc_profile  [label="Просмотр профиля", shape=ellipse];
        uc_editprof [label="Редактирование профиля", shape=ellipse];

        uc_create   [label="Создание мероприятия", shape=ellipse];
        uc_edit     [label="Редактирование мероприятия", shape=ellipse];
        uc_delete   [label="Удаление мероприятия", shape=ellipse];

        uc_viewapps [label="Просмотр списка\nподанных заявок", shape=ellipse];
    }

    coordinator -> uc_home;
    coordinator -> uc_events;
    coordinator -> uc_event;
    coordinator -> uc_filter;
    coordinator -> uc_profile;
    coordinator -> uc_editprof;
    coordinator -> uc_create;
    coordinator -> uc_edit;
    coordinator -> uc_delete;
    coordinator -> uc_viewapps;
}