digraph BP5_AdminManagement {

    rankdir=TB;
    ranksep=0.9;
    nodesep=0.6;
    fontsize=11;
    fontname="Segoe UI";
    node [fontname="Segoe UI", shape=box];

    start [label="Начало администрирования", shape=oval, style=filled, fillcolor="lightgrey"];
    end_ok [label="Завершение процесса", shape=oval, style=filled, fillcolor="lightgrey"];

    subgraph cluster_admin {
        label="Администратор";
        style="rounded";
        color="lightyellow";

        a_view_users [label="Просмотр\nпользователей"];
        a_change_roles [label="Изменение\nролей"];
        a_block_user [label="Блокировка\nаккаунта"];
        a_unblock_user [label="Разблокировка\nаккаунта"];
        a_manage_categories [label="Управление\nкатегориями\nмероприятий"];
        a_view_stats [label="Просмотр\nсводной статистики"];
    }

    subgraph cluster_system {
        label="Информационная система";
        style="rounded";
        color="lightblue";

        s_update_roles [label="Обновление\nролей"];
        s_update_status [label="Изменение\nстатуса аккаунта"];
        s_save_categories [label="Сохранение\nкатегорий"];
        s_generate_stats [label="Формирование\nстатистики"];
    }

    start -> a_view_users -> a_change_roles -> s_update_roles;
    a_block_user -> s_update_status;
    a_unblock_user -> s_update_status;
    a_manage_categories -> s_save_categories;
    a_view_stats -> s_generate_stats -> end_ok;
}