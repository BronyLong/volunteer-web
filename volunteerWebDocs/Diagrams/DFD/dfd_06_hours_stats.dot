digraph DFD_Level2_Hours_Stats {
    graph [fontname="Segoe UI", fontsize=11, ranksep=1.0, nodesep=0.55, splines=true, overlap=false, pad=0.25, bgcolor="white"];
    node [fontname="Segoe UI", fontsize=11, margin="0.18,0.10"];
    edge [fontname="Segoe UI", fontsize=10, color="#5A5A5A", arrowsize=0.8, penwidth=1.3];

    rankdir=LR;
    label="DFD — Учёт волонтёрских часов и статистика";
    labelloc=t;
    volunteer [label="Волонтёр", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    coordinator [label="Координатор", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    admin [label="Администратор", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    p1 [label="Подтверждение участия", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    p2 [label="Начисление и корректировка часов", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    p3 [label="Формирование личной статистики", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    p4 [label="Сводная аналитика", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    d1 [label="Подтверждённые заявки", shape=cylinder, style=filled, fillcolor="#F6FFF6"];
    d2 [label="Учёт часов", shape=cylinder, style=filled, fillcolor="#F6FFF6"];
    e1 [shape=plaintext, label="фактические
участники"];
    e2 [shape=plaintext, label="проверка участия"];
    e3 [shape=plaintext, label="подтверждённые
волонтёры"];
    e4 [shape=plaintext, label="количество часов"];
    e5 [shape=plaintext, label="записи по часам"];
    e6 [shape=plaintext, label="результат
начисления"];
    e7 [shape=plaintext, label="запрос личной
статистики"];
    e8 [shape=plaintext, label="история часов"];
    e9 [shape=plaintext, label="общее число часов,
мероприятий и динамика"];
    e10 [shape=plaintext, label="запрос общей
аналитики"];
    e11 [shape=plaintext, label="агрегированные
данные"];
    e12 [shape=plaintext, label="сводная статистика
по системе"];
    coordinator -> e1; e1 -> p1;
    p1 -> e2; e2 -> d1;
    p1 -> e3; e3 -> p2;
    coordinator -> e4; e4 -> p2;
    p2 -> e5; e5 -> d2;
    p2 -> e6; e6 -> coordinator;
    volunteer -> e7; e7 -> p3;
    p3 -> e8; e8 -> d2;
    p3 -> e9; e9 -> volunteer;
    admin -> e10; e10 -> p4;
    p4 -> e11; e11 -> d2;
    p4 -> e12; e12 -> admin;

}
