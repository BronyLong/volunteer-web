digraph DFD_Level2_Auth {
    graph [fontname="Segoe UI", fontsize=11, ranksep=1.0, nodesep=0.55, splines=true, overlap=false, pad=0.25, bgcolor="white"];
    node [fontname="Segoe UI", fontsize=11, margin="0.18,0.10"];
    edge [fontname="Segoe UI", fontsize=10, color="#5A5A5A", arrowsize=0.8, penwidth=1.3];

    rankdir=LR;
    label="DFD — Регистрация и аутентификация";
    labelloc=t;
    guest [label="Гость / новый пользователь", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    volunteer [label="Авторизованный пользователь", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    p1 [label="Регистрация", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    p2 [label="Вход в систему", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    p3 [label="Проверка ролей и доступа", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    d1 [label="Пользователи и роли", shape=cylinder, style=filled, fillcolor="#F6FFF6"];
    d2 [label="Журнал входов", shape=cylinder, style=filled, fillcolor="#F6FFF6"];
    a1 [shape=plaintext, label="email, пароль,
базовые данные"];
    a2 [shape=plaintext, label="новая учётная запись"];
    a3 [shape=plaintext, label="подтверждение
регистрации"];
    a4 [shape=plaintext, label="учётные данные"];
    a5 [shape=plaintext, label="поиск пользователя"];
    a6 [shape=plaintext, label="учётная запись
и роль"];
    a7 [shape=plaintext, label="факт входа"];
    a8 [shape=plaintext, label="JWT / сессия"];
    a9 [shape=plaintext, label="результат авторизации
и доступные разделы"];
    guest -> a1; a1 -> p1;
    p1 -> a2; a2 -> d1;
    p1 -> a3; a3 -> guest;
    guest -> a4; a4 -> p2;
    p2 -> a5; a5 -> d1;
    d1 -> a6; a6 -> p2;
    p2 -> a7; a7 -> d2;
    p2 -> a8; a8 -> p3;
    p3 -> a9; a9 -> volunteer;

}
