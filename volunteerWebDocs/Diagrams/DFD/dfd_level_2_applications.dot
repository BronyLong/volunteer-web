digraph DFD_Level2_Applications {
    graph [
        rankdir=TB,
        splines=polyline,
        bgcolor="white",
        pad=0.5,
        nodesep=1.2,
        ranksep=1.3,
        fontname="Segoe UI",
        fontsize=18
    ];

    node [
        fontname="Segoe UI",
        fontsize=18,
        style="rounded",
        margin="0.30,0.20"
    ];

    edge [
        fontname="Segoe UI",
        fontsize=14
    ];

    volunteer [label="Волонтёр", shape=box];

    p411 [label="4.1.1 Проверка\nавторизации", shape=ellipse, style="filled", fillcolor="#FFF4CC"];
    p412 [label="4.1.2 Проверка\nповторной заявки", shape=ellipse, style="filled", fillcolor="#FFF4CC"];
    p413 [label="4.1.3 Проверка\nсвободных мест", shape=ellipse, style="filled", fillcolor="#FFF4CC"];
    p414 [label="4.1.4 Создание\nзаявки", shape=ellipse, style="filled", fillcolor="#FFF4CC"];
    p415 [label="4.1.5 Уменьшение\nсвободных мест", shape=ellipse, style="filled", fillcolor="#FFF4CC"];

    p421 [label="4.2.1 Проверка\nавторизации", shape=ellipse, style="filled", fillcolor="#FFF4CC"];
    p422 [label="4.2.2 Проверка наличия\nактивной заявки", shape=ellipse, style="filled", fillcolor="#FFF4CC"];
    p423 [label="4.2.3 Удаление\nзаявки", shape=ellipse, style="filled", fillcolor="#FFF4CC"];
    p424 [label="4.2.4 Увеличение\nсвободных мест", shape=ellipse, style="filled", fillcolor="#FFF4CC"];

    d3 [label="D3. Мероприятия", shape=cylinder];
    d4 [label="D4. Заявки", shape=cylinder];

    volunteer -> p411 [label="Запрос на подачу"];
    p415 -> volunteer [label="Статус:\nзаявка отправлена"];

    volunteer -> p421 [label="Запрос на отмену"];
    p424 -> volunteer [label="Статус:\nзаявка не подана"];

    p411 -> p412 [label="Авторизован"];
    p412 -> d4 [label="Проверка дубля"];
    d4 -> p412 [label="Результат"];
    p412 -> p413 [label="Дубля нет"];
    p413 -> d3 [label="Чтение мест"];
    d3 -> p413 [label="Количество мест"];
    p413 -> p414 [label="Места есть"];
    p414 -> d4 [label="Создание"];
    d4 -> p414 [label="Созданная заявка"];
    p414 -> p415 [label="Обновить места"];
    p415 -> d3 [label="Уменьшение\navailableSlots"];
    d3 -> p415 [label="Обновлённые данные"];

    p421 -> p422 [label="Авторизован"];
    p422 -> d4 [label="Проверка наличия"];
    d4 -> p422 [label="Результат"];
    p422 -> p423 [label="Заявка найдена"];
    p423 -> d4 [label="Удаление"];
    d4 -> p423 [label="Результат удаления"];
    p423 -> p424 [label="Обновить места"];
    p424 -> d3 [label="Увеличение\navailableSlots"];
    d3 -> p424 [label="Обновлённые данные"];
}