digraph DFD_Level2_News {
    graph [fontname="Segoe UI", fontsize=11, ranksep=1.0, nodesep=0.55, splines=true, overlap=false, pad=0.25, bgcolor="white"];
    node [fontname="Segoe UI", fontsize=11, margin="0.18,0.10"];
    edge [fontname="Segoe UI", fontsize=10, color="#5A5A5A", arrowsize=0.8, penwidth=1.3];

    rankdir=LR;
    label="DFD — Новостной модуль";
    labelloc=t;
    guest [label="Гость", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    volunteer [label="Волонтёр", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    coordinator [label="Координатор", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    admin [label="Администратор", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    p1 [label="Создание и редактирование новости", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    p2 [label="Публикация новостей", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    p3 [label="Просмотр новостной ленты", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    d1 [label="Новости", shape=cylinder, style=filled, fillcolor="#F6FFF6"];
    g1 [shape=plaintext, label="заголовок, текст,
дата публикации"];
    g2 [shape=plaintext, label="создание или
модерация новости"];
    g3 [shape=plaintext, label="черновик /
обновлённая запись"];
    g4 [shape=plaintext, label="публикация записи"];
    g5 [shape=plaintext, label="запрос списка
новостей"];
    g6 [shape=plaintext, label="просмотр новости"];
    g7 [shape=plaintext, label="новостная лента
и детали публикации"];
    g8 [shape=plaintext, label="новостная лента
и детали публикации"];
    g9 [shape=plaintext, label="чтение новостей"];
    coordinator -> g1; g1 -> p1;
    admin -> g2; g2 -> p1;
    p1 -> g3; g3 -> d1;
    p1 -> p2 [label="готовая новость"];
    p2 -> g4; g4 -> d1;
    guest -> g5; g5 -> p3;
    volunteer -> g6; g6 -> p3;
    p3 -> g7; g7 -> guest;
    p3 -> g8; g8 -> volunteer;
    p3 -> g9; g9 -> d1;

}
