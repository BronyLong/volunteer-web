digraph DFD_Level2_Apps {
    graph [fontname="Segoe UI", fontsize=11, ranksep=1.0, nodesep=0.55, splines=true, overlap=false, pad=0.25, bgcolor="white"];
    node [fontname="Segoe UI", fontsize=11, margin="0.18,0.10"];
    edge [fontname="Segoe UI", fontsize=10, color="#5A5A5A", arrowsize=0.8, penwidth=1.3];

    rankdir=LR;
    label="DFD — Запись на мероприятия и обработка заявок";
    labelloc=t;
    volunteer [label="Волонтёр", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    coordinator [label="Координатор", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    p1 [label="Подача заявки", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    p2 [label="Проверка мест и ограничений", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    p3 [label="Рассмотрение заявок", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    p4 [label="Отмена заявки", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    d1 [label="Мероприятия", shape=cylinder, style=filled, fillcolor="#F6FFF6"];
    d2 [label="Заявки", shape=cylinder, style=filled, fillcolor="#F6FFF6"];
    d3 [label="Профили", shape=cylinder, style=filled, fillcolor="#F6FFF6"];
    d11 [shape=plaintext, label="выбор мероприятия"];
    d12 [shape=plaintext, label="данные о событии"];
    d13 [shape=plaintext, label="чтение лимита
и статуса"];
    d14 [shape=plaintext, label="разрешение на
регистрацию"];
    d15 [shape=plaintext, label="новая заявка"];
    d16 [shape=plaintext, label="статус: ожидание"];
    d17 [shape=plaintext, label="просмотр поступивших
заявок"];
    d18 [shape=plaintext, label="список заявок"];
    d19 [shape=plaintext, label="данные волонтёров"];
    d20 [shape=plaintext, label="подтверждение
или отклонение"];
    d21 [shape=plaintext, label="решение по заявкам"];
    d22 [shape=plaintext, label="обновлённый статус"];
    d23 [shape=plaintext, label="отзыв заявки"];
    d24 [shape=plaintext, label="изменение статуса"];
    d25 [shape=plaintext, label="заявка отменена"];
    volunteer -> d11; d11 -> p1;
    p1 -> d12; d12 -> p2;
    p2 -> d13; d13 -> d1;
    p2 -> d14; d14 -> p1;
    p1 -> d15; d15 -> d2;
    p1 -> d16; d16 -> volunteer;
    coordinator -> d17; d17 -> p3;
    p3 -> d18; d18 -> d2;
    p3 -> d19; d19 -> d3;
    p3 -> d20; d20 -> d2;
    p3 -> d21; d21 -> coordinator;
    p3 -> d22; d22 -> volunteer;
    volunteer -> d23; d23 -> p4;
    p4 -> d24; d24 -> d2;
    p4 -> d25; d25 -> volunteer;

}
