digraph DFD_Level0 {
    graph [fontname="Segoe UI", fontsize=11, ranksep=1.0, nodesep=0.55, splines=true, overlap=false, pad=0.25, bgcolor="white"];
    node [fontname="Segoe UI", fontsize=11, margin="0.18,0.10"];
    edge [fontname="Segoe UI", fontsize=10, color="#5A5A5A", arrowsize=0.8, penwidth=1.3];

    rankdir=LR;
    label="DFD Level 0 — Контекстная диаграмма";
    labelloc=t;
    guest [label="Гость / потенциальный
волонтёр", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    volunteer [label="Волонтёр", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    coordinator [label="Координатор", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    admin [label="Администратор", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    system [label="Информационная система
волонтёрской организации", shape=ellipse, style="filled", fillcolor="#F3E7B3", color="#8A7A33", penwidth=1.4];
    f1 [label="публичная информация
о сайте, новостях
и мероприятиях", shape=plaintext];
    f2 [label="регистрационные данные
и запросы просмотра", shape=plaintext];
    f3 [label="результат авторизации,
данные профиля,
мои заявки и статистика", shape=plaintext];
    f4 [label="заявки на участие,
запросы к профилю
и статистике", shape=plaintext];
    f5 [label="данные мероприятия,
решения по заявкам,
подтверждение часов", shape=plaintext];
    f5b [label="данные по заявкам,
волонтёрам и часам", shape=plaintext];
    f6 [label="настройки ролей,
категорий, пользователей,
новостей и мероприятий", shape=plaintext];
    f7 [label="сводная статистика,
список пользователей,
журнал действий", shape=plaintext];
    guest -> f2; f2 -> system;
    system -> f1; f1 -> guest;
    volunteer -> f4; f4 -> system;
    system -> f3; f3 -> volunteer;
    coordinator -> f5; f5 -> system;
    system -> f5b; f5b -> coordinator;
    admin -> f6; f6 -> system;
    system -> f7; f7 -> admin;

}
