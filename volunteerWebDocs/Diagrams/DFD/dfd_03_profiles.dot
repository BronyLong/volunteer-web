digraph DFD_Level2_Profiles {
    graph [fontname="Segoe UI", fontsize=11, ranksep=1.0, nodesep=0.55, splines=true, overlap=false, pad=0.25, bgcolor="white"];
    node [fontname="Segoe UI", fontsize=11, margin="0.18,0.10"];
    edge [fontname="Segoe UI", fontsize=10, color="#5A5A5A", arrowsize=0.8, penwidth=1.3];

    rankdir=LR;
    label="DFD — Управление профилями пользователей";
    labelloc=t;
    volunteer [label="Волонтёр", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    coordinator [label="Координатор", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    admin [label="Администратор", shape=box, style="rounded,filled", fillcolor="#F7F7F7"];
    p1 [label="Просмотр профиля", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    p2 [label="Редактирование профиля", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    p3 [label="Управление ролями и статусом", shape=ellipse, style=filled, fillcolor="#FFF5CC"];
    d1 [label="Пользователи и роли", shape=cylinder, style=filled, fillcolor="#F6FFF6"];
    d2 [label="Профили", shape=cylinder, style=filled, fillcolor="#F6FFF6"];
    b1 [shape=plaintext, label="запрос профиля"];
    b2 [shape=plaintext, label="данные аккаунта"];
    b3 [shape=plaintext, label="данные профиля"];
    b4 [shape=plaintext, label="личные данные,
контакты, bio, аватар"];
    b5 [shape=plaintext, label="изменённые
данные профиля"];
    b6 [shape=plaintext, label="обновление анкеты"];
    b7 [shape=plaintext, label="обновлённый профиль"];
    b8 [shape=plaintext, label="запрос профиля
волонтёра"];
    b9 [shape=plaintext, label="контакты и анкета"];
    b10 [shape=plaintext, label="изменение роли
или блокировки"];
    b11 [shape=plaintext, label="новая роль / статус"];
    b12 [shape=plaintext, label="подтверждение
изменений"];
    volunteer -> b1; b1 -> p1;
    p1 -> b2; b2 -> d1;
    p1 -> b3; b3 -> d2;
    p1 -> b4; b4 -> volunteer;
    volunteer -> b5; b5 -> p2;
    p2 -> b6; b6 -> d2;
    p2 -> b7; b7 -> volunteer;
    coordinator -> b8; b8 -> p1;
    p1 -> b9; b9 -> coordinator;
    admin -> b10; b10 -> p3;
    p3 -> b11; b11 -> d1;
    p3 -> b12; b12 -> admin;

}
