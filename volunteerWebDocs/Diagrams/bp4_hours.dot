digraph BP4_VolunteerHours {

    rankdir=TB;
    ranksep=0.9;
    nodesep=0.6;
    fontsize=11;
    fontname="Segoe UI";
    node [fontname="Segoe UI", shape=box];

    start [label="Начало мероприятия", shape=oval, style=filled, fillcolor="lightgrey"];
    end_ok [label="Завершение процесса\n(часы учтены)", shape=oval, style=filled, fillcolor="lightgrey"];

    subgraph cluster_volunteer {
        label="Волонтёры";
        style="rounded";
        color="lightyellow";

        v_participate [label="Участие\nв мероприятии"];
    }

    subgraph cluster_coordinator {
        label="Координатор";
        style="rounded";
        color="lightgreen";

        c_check_attendance [label="Фиксация\nучастников"];
        c_enter_hours [label="Ввод количества\nотработанных часов"];
        c_correct_hours [label="Корректировка\nчасов (при ошибке)"];
    }

    subgraph cluster_system {
        label="Информационная система";
        style="rounded";
        color="lightblue";

        s_save_hours [label="Сохранение данных\nо часах"];
        s_update_stats [label="Обновление\nстатистики волонтёра"];
    }

    start -> v_participate -> c_check_attendance -> c_enter_hours;
    c_enter_hours -> s_save_hours -> s_update_stats -> end_ok;

    c_correct_hours -> s_save_hours;
}