digraph BP6_NewsAndAttraction {

    rankdir=TB;
    ranksep=0.9;
    nodesep=0.6;
    fontsize=11;
    fontname="Segoe UI";
    node [fontname="Segoe UI", shape=box];

    start [label="Начало процесса", shape=oval, style=filled, fillcolor="lightgrey"];
    end_ok [label="Новость опубликована", shape=oval, style=filled, fillcolor="lightgrey"];

    subgraph cluster_staff {
        label="Координатор / Администратор";
        style="rounded";
        color="lightyellow";

        s_prepare_news [label="Подготовка\nинформационного\nматериала"];
        s_create_news [label="Создание\nновостной записи"];
        s_edit_news [label="Редактирование\nили обновление"];
    }

    subgraph cluster_system {
        label="Информационная система";
        style="rounded";
        color="lightblue";

        sys_validate [label="Проверка\nданных публикации"];
        sys_publish [label="Публикация\nновости"];
    }

    subgraph cluster_users {
        label="Пользователи и гости";
        style="rounded";
        color="lightgreen";

        u_read_news [label="Просмотр\nновостей"];
        u_go_events [label="Переход\nк мероприятиям"];
    }

    start -> s_prepare_news -> s_create_news -> sys_validate;
    sys_validate -> sys_publish -> u_read_news -> u_go_events -> end_ok;

    s_edit_news -> sys_validate;
}