digraph BP3_EventRegistration {

    rankdir=TB;
    ranksep=0.9;
    nodesep=0.6;
    fontsize=11;
    fontname="Segoe UI";
    node [fontname="Segoe UI", shape=box];

    start [label="Начало процесса", shape=oval, style=filled, fillcolor="lightgrey"];
    end_ok [label="Завершение процесса\n(список участников\nсформирован)", shape=oval, style=filled, fillcolor="lightgrey"];

    subgraph cluster_volunteer {
        label="Волонтёр";
        style="rounded";
        color="lightyellow";

        v_view_events [label="Просмотр списка\nмероприятий"];
        v_open_event [label="Просмотр карточки\nмероприятия"];
        v_apply [label="Подача заявки\nна участие"];
        v_cancel [label="Отмена заявки"];
    }

    subgraph cluster_system {
        label="Информационная система";
        style="rounded";
        color="lightblue";

        s_check_limit [label="Проверка статуса\nи лимита участников"];
        s_create_application [label="Создание заявки\nсо статусом\n«ожидание»"];
        s_update_status [label="Обновление\nстатуса заявки"];
    }

    subgraph cluster_coordinator {
        label="Координатор";
        style="rounded";
        color="lightgreen";

        c_view_apps [label="Просмотр заявок"];
        c_accept [label="Подтверждение\nучастия"];
        c_reject [label="Отклонение\nзаявки"];
    }

    start -> v_view_events -> v_open_event -> v_apply -> s_check_limit;

    s_check_limit -> s_create_application [label="места есть"];
    s_create_application -> c_view_apps;

    c_view_apps -> c_accept -> s_update_status;
    c_view_apps -> c_reject -> s_update_status;

    v_cancel -> s_update_status;

    s_update_status -> end_ok;
}