digraph BP2_EventManagement {

    rankdir=TB;
    ranksep=0.9;
    nodesep=0.6;
    fontsize=11;
    fontname="Segoe UI";
    node [fontname="Segoe UI", shape=box];

    start [label="Начало процесса", shape=oval, style=filled, fillcolor="lightgrey"];
    end_ok [label="Завершение процесса\n(мероприятие создано\nили обновлено)", shape=oval, style=filled, fillcolor="lightgrey"];

    subgraph cluster_coordinator {
        label="Координатор";
        style="rounded";
        color="lightyellow";

        c_plan_event [label="Формирование идеи\nи параметров мероприятия"];
        c_create_event [label="Создание карточки\nмероприятия"];
        c_edit_event [label="Редактирование\nданных мероприятия"];
        c_finish_event [label="Перевод статуса\nв «завершено»"];
        c_cancel_event [label="Перевод статуса\nв «отменено»"];
    }

    subgraph cluster_system {
        label="Информационная система";
        style="rounded";
        color="lightblue";

        s_validate_event [label="Проверка корректности\nвведённых данных"];
        s_save_event [label="Сохранение\nмероприятия"];
        s_publish_event [label="Публикация мероприятия\nв списке"];
        s_update_event [label="Обновление\nданных мероприятия"];
    }

    subgraph cluster_admin {
        label="Администратор";
        style="rounded";
        color="lightgreen";

        a_edit_event [label="Административное\nредактирование\nмероприятия"];
        a_delete_event [label="Удаление\nнекорректного\nмероприятия"];
    }

    start -> c_plan_event -> c_create_event -> s_validate_event;
    s_validate_event -> s_save_event;
    s_save_event -> s_publish_event -> end_ok;

    c_edit_event -> s_update_event -> end_ok;
    c_finish_event -> s_update_event;
    c_cancel_event -> s_update_event;

    a_edit_event -> s_update_event;
    a_delete_event -> end_ok;
}