digraph BP1_AccountManagement {

    rankdir=TB;
    ranksep=0.9;
    nodesep=0.6;
    fontsize=11;
    fontname="Segoe UI";
    node [fontname="Segoe UI", shape=box];

    start  [label="Начало процесса", shape=oval, style=filled, fillcolor="lightgrey"];
    end_ok [label="Завершение процесса\n(пользователь зарегистрирован\nи профиль заполнен)", shape=oval, style=filled, fillcolor="lightgrey"];
    end_fail [label="Завершение процесса\n(регистрация отклонена)", shape=oval, style=filled, fillcolor="lightgrey"];

    // Потенциальный волонтёр
    subgraph cluster_volunteer {
        label = "Потенциальный пользователь / волонтёр";
        style = "rounded";
        color = "lightyellow";

        v_visit_site   [label="Переход на сайт\nволонтёрской организации"];
        v_register     [label="Заполнение формы\nрегистрации"];
        v_login        [label="Ввод email\nи пароля"];
        v_edit_profile [label="Заполнение\nи редактирование\nличного профиля"];
    }

    // Система
    subgraph cluster_system {
        label = "Информационная система";
        style = "rounded";
        color = "lightblue";

        s_validate_data  [label="Проверка корректности\nданных регистрации"];
        s_check_email    [label="Проверка уникальности\nemail"];
        s_create_account [label="Создание учётной записи\n(роль «волонтёр»)"];
        s_authenticate   [label="Проверка учётных данных"];
        s_open_dashboard [label="Предоставление доступа\nк личному кабинету"];
        s_save_profile   [label="Сохранение данных\nпрофиля"];
        s_email_error    [label="Отказ в регистрации\n(email уже используется)"];
    }

    // Администратор
    subgraph cluster_admin {
        label = "Администратор";
        style = "rounded";
        color = "lightgreen";

        a_view_users   [label="Просмотр списка\nпользователей"];
        a_change_role  [label="Изменение ролей\nпользователей"];
        a_block_user   [label="Блокировка /\nразблокировка аккаунта"];
    }

    // Основной поток
    start -> v_visit_site -> v_register -> s_validate_data -> s_check_email;

    s_check_email -> s_create_account [label="email свободен"];
    s_check_email -> s_email_error [label="email занят", style=dashed];

    s_create_account -> v_login -> s_authenticate -> s_open_dashboard -> v_edit_profile -> s_save_profile -> end_ok;

    s_email_error -> end_fail;

    // Администрирование
    a_view_users -> a_change_role -> a_block_user;
}